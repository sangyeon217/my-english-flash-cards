# Neon Postgres 연결 문자열 (neon.tech 또는 Vercel Postgres 대시보드에서 복사)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 앱 접근 비밀번호 (최소 8자)
ACCESS_PASSWORD=change-me-please

# iron-session 암호화 시크릿 (최소 32자) — 예: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars
